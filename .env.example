# Copy to .env and adjust. Paths relative to repo root unless absolute.

DATABASE_URL=postgresql+psycopg2://pi:pi123@localhost:5432/procurement
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Pre-commit (Windows): use a repo-local cache if %USERPROFILE%\.cache is not writable
# PRE_COMMIT_HOME=./.cache/pre-commit

# Connector execution (scraping governance)
# CONNECTOR_MIN_INTERVAL_SEC=2
# CONNECTOR_MAX_RETRIES=3
# CONNECTOR_BACKOFF_BASE_SEC=1.5
# SCRAPING_ROBOTS_MODE=advisory

# Optional enrichment HTTP fallback (see backend/app/services/enrichment_sources.py)
# B2B_ENRICHMENT_API=https://example.com/enrich/vendors
# B2C_ATTRIBUTE_API=https://example.com/enrich/products
