# ─── Database ────────────────────────────────────────────────────────────────
# Use PostgreSQL in production. SQLite is the default for development.
# DATABASE_URL=postgresql://user:password@localhost:5432/procurement_db
DATABASE_URL=sqlite:///./dev.db

# ─── Authentication ───────────────────────────────────────────────────────────
# REQUIRED: Change this to a long random secret in production
JWT_SECRET_KEY=change-me-to-a-very-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ─── Payment Gateways ────────────────────────────────────────────────────────
# Stripe (https://dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay (https://dashboard.razorpay.com/app/keys)
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...

# Which gateway to use by default (stripe | razorpay | mock)
DEFAULT_PAYMENT_GATEWAY=mock

# ─── Email Service ────────────────────────────────────────────────────────────
# SendGrid (https://app.sendgrid.com/settings/api_keys)
# SENDGRID_API_KEY=SG....

# SMTP (Gmail, Outlook, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@yourcompany.com
# SMTP_FROM_NAME=Procurement Platform

# Email backend: auto | smtp | sendgrid | console (default: auto → console in dev)
EMAIL_BACKEND=console

# ─── Vendor Discovery Connectors ─────────────────────────────────────────────
# Google Maps Places API
# GOOGLE_MAPS_API_KEY=AIza...

# LinkedIn API (for vendor discovery)
# LINKEDIN_CLIENT_ID=...
# LINKEDIN_CLIENT_SECRET=...

# IndiaMART API
# INDIAMART_API_KEY=...

# Custom supplier feed CSV path
# SUPPLIER_FEED_CSV=/path/to/supplier_feed.csv

# ─── Data Enrichment ─────────────────────────────────────────────────────────
# Override default CSV paths
# B2B_ENRICHMENT_CSV=/path/to/b2b_revenue.csv
# B2C_ATTRIBUTE_CSV=/path/to/b2c_attribute_feed.csv

# External enrichment APIs (optional)
# B2B_ENRICHMENT_API=https://your-enrichment-api.com/b2b
# B2C_ATTRIBUTE_API=https://your-enrichment-api.com/b2c

# ─── Redis / Background Tasks ────────────────────────────────────────────────
# Redis is optional. Without it, the in-process task runner is used.
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Notifications ────────────────────────────────────────────────────────────
# Twilio SMS (optional)
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+15551234567

# ─── Frontend ────────────────────────────────────────────────────────────────
# URL of the backend API (used by Next.js rewrites)
BACKEND_URL=http://localhost:8000
